generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model EnterpriseProfile {
  id              Int             @id @default(autoincrement())
  enterprise_code String          @unique
  type            String
  host_count      Int
  region          String
  predictions     PredictionLog[]

  @@index([region])
}

model Threat {
  id              Int              @id @default(autoincrement())
  code            String           @unique
  name            String
  description     String?
  object          String?
  source          String?
  cia_flags       String?
  cluster         String?
  recommendations Recommendation[]
  predictions     PredictionLog[]

  @@index([cluster])
}

model PredictionLog {
  id                String            @id @default(uuid())
  request_id        String            @unique
  enterprise_code   String
  enterprise        EnterpriseProfile @relation(fields: [enterprise_code], references: [enterprise_code], onDelete: Cascade)
  probability       Float
  predicted_threat  String
  threat_details    Threat            @relation(fields: [predicted_threat], references: [code], onDelete: Restrict, onUpdate: Cascade)
  predicted_cluster String?
  predicted_object  String?
  season            String?
  day_of_week       Int?
  hour              Int?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  targetDate        DateTime?
  horizon           String?           @default("7d")
  report_md         String?
  estimated_damage  Float?

  @@map("PredictionLog")
  @@index([enterprise_code])
  @@index([createdAt])
  @@index([predicted_threat])
}

model Recommendation {
  id          Int    @id @default(autoincrement())
  rec_code    String @unique
  title       String
  description String
  priority    Int
  threatId    Int
  threat      Threat @relation(fields: [threatId], references: [id], onDelete: Cascade)

  @@index([threatId])
}