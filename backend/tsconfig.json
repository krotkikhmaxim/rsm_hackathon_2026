{
  "compilerOptions": {
    "target": "es2022",                
    "module": "commonjs",              
    "rootDir": ".",                    
    "outDir": "./dist",                
    "strict": true,                    
    "esModuleInterop": true,          
    "skipLibCheck": true,              
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", "routes"],
  "exclude": ["node_modules", "dist"]
}
